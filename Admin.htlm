\u003d\\u003cwbr\\u003eSora:wght@700;800\\u0026amp;family\\u003d\\u003cwbr\\u003eInter:wght@400;500;600;700\\u0026amp;\\u003cwbr\\u003edisplay\\u003dswap\\u003c/a\\u003e\\u0026quot; rel\\u003d\\u0026quot;stylesheet\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;style\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e:root{\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  --navy:#0B1F3A; --coral:#FF6B4A; --river:#178A8A; --cream:#FAF7F1;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  --ink:#13161B; --ink-soft:#5B6472; --line:#E7E1D6;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  --display:\\u0026#39;Sora\\u0026#39;, sans-serif; --body:\\u0026#39;Inter\\u0026#39;, sans-serif;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e*{margin:0;padding:0;box-\\u003cwbr\\u003esizing:border-box;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003ebody{font-family:var(--body);\\u003cwbr\\u003ebackground:var(--cream);color:\\u003cwbr\\u003evar(--ink);min-height:100vh;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.wrap{max-width:640px;margin:0 auto;padding:30px 20px 60px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003eh1{font-family:var(--display);\\u003cwbr\\u003efont-weight:800;color:var(--\\u003cwbr\\u003enavy);font-size:1.4rem;margin-\\u003cwbr\\u003ebottom:4px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.sub{color:var(--ink-soft);\\u003cwbr\\u003efont-size:0.85rem;margin-\\u003cwbr\\u003ebottom:28px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.card{background:#fff;border:\\u003cwbr\\u003e1px solid var(--line);border-radius:\\u003cwbr\\u003e16px;padding:20px;margin-\\u003cwbr\\u003ebottom:16px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003elabel{font-size:0.8rem;font-\\u003cwbr\\u003eweight:600;color:var(--ink-\\u003cwbr\\u003esoft);display:flex;flex-\\u003cwbr\\u003edirection:column;gap:6px;\\u003cwbr\\u003emargin-bottom:12px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003einput{border:1px solid var(--line);border-radius:\\u003cwbr\\u003e10px;padding:10px 12px;font-size:0.95rem;font-\\u003cwbr\\u003efamily:var(--body);outline:\\u003cwbr\\u003enone;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003einput:focus{border-color:var(-\\u003cwbr\\u003e-river);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn{font-family:var(--\\u003cwbr\\u003edisplay);font-weight:700;font-\\u003cwbr\\u003esize:0.85rem;padding:11px 18px;border-radius:999px;\\u003cwbr\\u003eborder:none;cursor:pointer;\\u003cwbr\\u003edisplay:inline-flex;align-\\u003cwbr\\u003eitems:center;gap:6px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-dark{background:var(--\\u003cwbr\\u003enavy);color:#fff;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-coral{background:var(--\\u003cwbr\\u003ecoral);color:#fff;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-outline{background:\\u003cwbr\\u003etransparent;border:1.5px solid var(--line);color:var(--ink);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-danger{background:#fff;\\u003cwbr\\u003ecolor:var(--coral);border:1.\\u003cwbr\\u003e5px solid var(--coral);font-size:0.\\u003cwbr\\u003e78rem;padding:7px 14px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.error{color:var(--coral);\\u003cwbr\\u003efont-size:0.82rem;min-height:\\u003cwbr\\u003e1em;margin-top:-4px;margin-\\u003cwbr\\u003ebottom:8px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-row{display:flex;\\u003cwbr\\u003ejustify-content:space-between;\\u003cwbr\\u003ealign-items:flex-start;gap:\\u003cwbr\\u003e12px;border-bottom:1px solid var(--line);padding:14px 0;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-row:last-child{\\u003cwbr\\u003eborder-bottom:none;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-row .info strong{display:block;font-\\u003cwbr\\u003efamily:var(--display);color:\\u003cwbr\\u003evar(--navy);font-size:0.95rem;\\u003cwbr\\u003e}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-row .info span{font-size:0.78rem;color:\\u003cwbr\\u003evar(--river);font-weight:600;\\u003cwbr\\u003etext-transform:uppercase;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-row .info p{font-size:0.82rem;color:var(\\u003cwbr\\u003e--ink-soft);margin-top:4px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.tag{display:inline-block;\\u003cwbr\\u003ebackground:var(--coral);color:\\u003cwbr\\u003e#fff;font-size:0.72rem;font-\\u003cwbr\\u003eweight:700;padding:2px 8px;border-radius:999px;\\u003cwbr\\u003emargin-top:4px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e#loginView, #adminView{display:none;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e#loginView.active, #adminView.active{display:\\u003cwbr\\u003eblock;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.topbar{display:flex;justify-\\u003cwbr\\u003econtent:space-between;align-\\u003cwbr\\u003eitems:center;margin-bottom:\\u003cwbr\\u003e24px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.hint{font-size:0.78rem;color:\\u003cwbr\\u003evar(--ink-soft);background:#\\u003cwbr\\u003efff;border:1px solid var(--line);border-radius:\\u003cwbr\\u003e12px;padding:14px;margin-\\u003cwbr\\u003ebottom:20px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;/style\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;/head\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;body\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;div class\\u003d\\u0026quot;wrap\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  \\u0026lt;div id\\u003d\\u0026quot;loginView\\u0026quot; class\\u003d\\u0026quot;active\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;h1\\u0026gt;Painel do Clube\\u0026lt;/h1\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;p class\\u003d\\u0026quot;sub\\u0026quot;\\u0026gt;Entre com sua conta de administrador pra gerenciar os parceiros.\\u0026lt;/p\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;div class\\u003d\\u0026quot;card\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;form id\\u003d\\u0026quot;loginForm\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;label\\u0026gt;E-mail\\u0026lt;input type\\u003d\\u0026quot;email\\u0026quot; id\\u003d\\u0026quot;loginEmail\\u0026quot; required\\u0026gt;\\u0026lt;/label\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;label\\u0026gt;Senha\\u0026lt;input type\\u003d\\u0026quot;password\\u0026quot; id\\u003d\\u0026quot;loginPassword\\u0026quot; required\\u0026gt;\\u0026lt;/label\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;p class\\u003d\\u0026quot;error\\u0026quot; id\\u003d\\u0026quot;loginError\\u0026quot;\\u0026gt;\\u0026lt;/p\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;button class\\u003d\\u0026quot;btn btn-dark\\u0026quot; type\\u003d\\u0026quot;submit\\u0026quot;\\u0026gt;Entrar\\u0026lt;/button\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;/form\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;p class\\u003d\\u0026quot;hint\\u0026quot;\\u0026gt;Esse login é só pra quem administra o clube (você ou o cliente dono da marca) — é diferente do cadastro de clientes finais no site.\\u0026lt;/p\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  \\u0026lt;div id\\u003d\\u0026quot;adminView\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;div class\\u003d\\u0026quot;topbar\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;h1\\u0026gt;Parceiros\\u0026lt;/h1\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;p class\\u003d\\u0026quot;sub\\u0026quot; id\\u003d\\u0026quot;welcomeMsg\\u0026quot;\\u0026gt;\\u0026lt;/p\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;button class\\u003d\\u0026quot;btn btn-outline\\u0026quot; id\\u003d\\u0026quot;logoutBtn\\u0026quot;\\u0026gt;Sair\\u0026lt;/button\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;div class\\u003d\\u0026quot;card\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;h3 style\\u003d\\u0026quot;font-family:var(--\\u003cwbr\\u003edisplay);color:var(--navy);\\u003cwbr\\u003emargin-bottom:14px;\\u0026quot;\\u0026gt;Adicionar parceiro\\u0026lt;/h3\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;form id\\u003d\\u0026quot;partnerForm\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;label\\u0026gt;Categoria\\u0026lt;input type\\u003d\\u0026quot;text\\u0026quot; id\\u003d\\u0026quot;pCat\\u0026quot; placeholder\\u003d\\u0026quot;Ex: Saúde\\u0026quot; required\\u0026gt;\\u0026lt;/label\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;label\\u0026gt;Nome do negócio\\u0026lt;input type\\u003d\\u0026quot;text\\u0026quot; id\\u003d\\u0026quot;pName\\u0026quot; placeholder\\u003d\\u0026quot;Ex: Farmácia São Francisco\\u0026quot; required\\u0026gt;\\u0026lt;/label\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;label\\u0026gt;Descrição da oferta\\u0026lt;input type\\u003d\\u0026quot;text\\u0026quot; id\\u003d\\u0026quot;pDesc\\u0026quot; placeholder\\u003d\\u0026quot;Ex: Desconto em medicamentos\\u0026quot; required\\u0026gt;\\u0026lt;/label\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;label\\u0026gt;Desconto (etiqueta)\\u0026lt;input type\\u003d\\u0026quot;text\\u0026quot; id\\u003d\\u0026quot;pTag\\u0026quot; placeholder\\u003d\\u0026quot;Ex: -18%\\u0026quot; required\\u0026gt;\\u0026lt;/label\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;p class\\u003d\\u0026quot;error\\u0026quot; id\\u003d\\u0026quot;partnerError\\u0026quot;\\u0026gt;\\u0026lt;/p\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;button class\\u003d\\u0026quot;btn btn-coral\\u0026quot; type\\u003d\\u0026quot;submit\\u0026quot;\\u0026gt;Adicionar parceiro\\u0026lt;/button\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;/form\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;div class\\u003d\\u0026quot;card\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;h3 style\\u003d\\u0026quot;font-family:var(--\\u003cwbr\\u003edisplay);color:var(--navy);\\u003cwbr\\u003emargin-bottom:8px;\\u0026quot;\\u0026gt;Parceiros cadastrados\\u0026lt;/h3\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;div id\\u003d\\u0026quot;partnersList\\u0026quot;\\u0026gt;\\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;script\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  // \\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003cwbr\\u003e\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  // Use os MESMOS valores de supabaseUrl/supabaseAnonKey do index.html\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  // E coloque seu e-mail (ou o do cliente) na lista de admins abaixo\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  // E TAMBÉM na política SQL do Supabase (veja o README).\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  // \\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003cwbr\\u003e\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  const CONFIG \\u003d {\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    supabaseUrl: \\u0026quot;SUA_SUPABASE_URL_AQUI\\u0026quot;,\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    supabaseAnonKey: \\u0026quot;SUA_SUPABASE_ANON_KEY_AQUI\\u0026quot;,\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    adminEmails: [\\u0026quot;\\u003ca href\\u003d\\\"mailto:seu-email@exemplo.com\\\" target\\u003d\\\"_blank\\\"\\u003eseu-email@exemplo.com\\u003c/a\\u003e\\u0026quot;]\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  };\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  const ready \\u003d CONFIG.supabaseUrl.startsWith(\\u003cwbr\\u003e\\u0026#39;http\\u0026#39;) \\u0026amp;\\u0026amp; CONFIG.supabaseAnonKey.length \\u0026gt; 20;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  if (!ready){\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    document.body.innerHTML \\u003d \\u0026#39;\\u0026lt;div class\\u003d\\u0026quot;wrap\\u0026quot;\\u0026gt;\\u0026lt;h1\\u0026gt;Painel não configurado\\u0026lt;/h1\\u0026gt;\\u0026lt;p class\\u003d\\u0026quot;sub\\u0026quot;\\u0026gt;Preencha CONFIG.supabaseUrl e CONFIG.supabaseAnonKey neste arquivo (admin.html), igual já fez no index.html.\\u0026lt;/p\\u0026gt;\\u0026lt;/div\\u0026gt;\\u0026#39;;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  } else {\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const supabase \\u003d window.supabase.createClient(\\u003cwbr\\u003eCONFIG.supabaseUrl, CONFIG.supabaseAnonKey);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const loginView \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003eloginView\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const adminView \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003eadminView\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const loginForm \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003eloginForm\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const loginError \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003eloginError\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const partnerForm \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003epartnerForm\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const partnerError \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003epartnerError\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const partnersList \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003epartnersList\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const logoutBtn \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003elogoutBtn\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const welcomeMsg \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003ewelcomeMsg\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    function showLogin(){ loginView.classList.add(\\u0026#39;\\u003cwbr\\u003eactive\\u0026#39;); adminView.classList.remove(\\u0026#39;\\u003cwbr\\u003eactive\\u0026#39;); }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    function showAdmin(email){\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      loginView.classList.remove(\\u0026#39;\\u003cwbr\\u003eactive\\u0026#39;); adminView.classList.add(\\u0026#39;\\u003cwbr\\u003eactive\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      welcomeMsg.textContent \\u003d `Logado como ${email}`;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      loadPartners();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    loginForm.addEventListener(\\u0026#39;\\u003cwbr\\u003esubmit\\u0026#39;, async (e) \\u003d\\u0026gt; {\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      e.preventDefault();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      loginError.textContent \\u003d \\u0026#39;\\u0026#39;;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const email \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003eloginEmail\\u0026#39;).value;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const password \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003eloginPassword\\u0026#39;).value;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const { data, error } \\u003d await supabase.auth.\\u003cwbr\\u003esignInWithPassword({ email, password });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      if (error){ loginError.textContent \\u003d \\u0026#39;E-mail ou senha incorretos.\\u0026#39;; return; }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      if (!CONFIG.adminEmails.includes(\\u003cwbr\\u003edata.user.email)){\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        loginError.textContent \\u003d \\u0026#39;Esta conta não tem acesso ao painel de administração.\\u0026#39;;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        await supabase.auth.signOut();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        return;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      showAdmin(data.user.email);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    logoutBtn.addEventListener(\\u0026#39;\\u003cwbr\\u003eclick\\u0026#39;, async () \\u003d\\u0026gt; {\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      await supabase.auth.signOut();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      showLogin();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    partnerForm.addEventListener(\\u0026#39;\\u003cwbr\\u003esubmit\\u0026#39;, async (e) \\u003d\\u0026gt; {\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      e.preventDefault();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      partnerError.textContent \\u003d \\u0026#39;\\u0026#39;;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const cat \\u003d document.getElementById(\\u0026#39;pCat\\u0026#39;\\u003cwbr\\u003e).value;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const name \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003epName\\u0026#39;).value;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const description \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003epDesc\\u0026#39;).value;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const tag \\u003d document.getElementById(\\u0026#39;pTag\\u0026#39;\\u003cwbr\\u003e).value;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const { error } \\u003d await supabase.from(\\u0026#39;partners\\u0026#39;).\\u003cwbr\\u003einsert({ cat, name, description, tag });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      if (error){ partnerError.textContent \\u003d \\u0026#39;Erro ao salvar: \\u0026#39; + error.message; return; }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      partnerForm.reset();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      loadPartners();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    async function loadPartners(){\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const { data, error } \\u003d await supabase.from(\\u0026#39;partners\\u0026#39;).\\u003cwbr\\u003eselect(\\u0026#39;*\\u0026#39;).order(\\u0026#39;created_at\\u0026#39;\\u003cwbr\\u003e, { ascending: true });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      if (error || !data){ partnersList.innerHTML \\u003d \\u0026#39;\\u0026lt;p class\\u003d\\u0026quot;sub\\u0026quot;\\u0026gt;Nenhum parceiro cadastrado ainda.\\u0026lt;/p\\u0026gt;\\u0026#39;; return; }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      if (data.length \\u003d\\u003d\\u003d 0){ partnersList.innerHTML \\u003d \\u0026#39;\\u0026lt;p class\\u003d\\u0026quot;sub\\u0026quot;\\u0026gt;Nenhum parceiro cadastrado ainda. O site vai mostrar exemplos até você adicionar o primeiro real.\\u0026lt;/p\\u0026gt;\\u0026#39;; return; }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      partnersList.innerHTML \\u003d data.map(p \\u003d\\u0026gt; `\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;div class\\u003d\\u0026quot;partner-row\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e          \\u0026lt;div class\\u003d\\u0026quot;info\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e            \\u0026lt;span\\u0026gt;${\\u003ca href\\u003d\\\"http://p.cat\\\" target\\u003d\\\"_blank\\\" data-saferedirecturl\\u003d\\\"https://www.google.com/url?q\\u003dhttp://p.cat\\u0026amp;source\\u003dgmail\\u0026amp;ust\\u003d1782379798321000\\u0026amp;usg\\u003dAOvVaw1YsWY7iqUzX0f4VD26iN82\\\"\\u003ep.cat\\u003c/a\\u003e}\\u0026lt;/span\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e            \\u0026lt;strong\\u0026gt;${\\u003ca href\\u003d\\\"http://p.name\\\" target\\u003d\\\"_blank\\\" data-saferedirecturl\\u003d\\\"https://www.google.com/url?q\\u003dhttp://p.name\\u0026amp;source\\u003dgmail\\u0026amp;ust\\u003d1782379798321000\\u0026amp;usg\\u003dAOvVaw3cdYLzAXdXe9Np10YO19n8\\\"\\u003ep.name\\u003c/a\\u003e}\\u0026lt;/strong\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e            \\u0026lt;p\\u0026gt;${p.description}\\u0026lt;/p\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e            \\u0026lt;span class\\u003d\\u0026quot;tag\\u0026quot;\\u0026gt;${p.tag}\\u0026lt;/span\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e          \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e          \\u0026lt;button class\\u003d\\u0026quot;btn-danger\\u0026quot; data-id\\u003d\\u0026quot;${\\u003ca href\\u003d\\\"http://p.id\\\" target\\u003d\\\"_blank\\\" data-saferedirecturl\\u003d\\\"https://www.google.com/url?q\\u003dhttp://p.id\\u0026amp;source\\u003dgmail\\u0026amp;ust\\u003d1782379798321000\\u0026amp;usg\\u003dAOvVaw0_vktpRMtvSbG7NCFgcS6w\\\"\\u003ep.id\\u003c/a\\u003e}\\u0026quot;\\u0026gt;Remover\\u0026lt;/\\u003cwbr\\u003ebutton\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      `).join(\\u0026#39;\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      partnersList.querySelectorAll(\\u003cwbr\\u003e\\u0026#39;button[data-id]\\u0026#39;).forEach(btn \\u003d\\u0026gt; {\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        btn.addEventListener(\\u0026#39;click\\u0026#39;, async () \\u003d\\u0026gt; {\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e          if (!confirm(\\u0026#39;Remover este parceiro?\\u0026#39;)) return;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e          await supabase.from(\\u0026#39;partners\\u0026#39;).\\u003cwbr\\u003edelete().eq(\\u0026#39;id\\u0026#39;, \\u003ca href\\u003d\\\"http://btn.dataset.id\\\" target\\u003d\\\"_blank\\\" data-saferedirecturl\\u003d\\\"https://www.google.com/url?q\\u003dhttp://btn.dataset.id\\u0026amp;source\\u003dgmail\\u0026amp;ust\\u003d1782379798321000\\u0026amp;usg\\u003dAOvVaw02A81nJDNq4071LaS2jlyn\\\"\\u003ebtn.dataset.id\\u003c/a\\u003e);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e          loadPartners();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    // mantém logado se já tinha sessão\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    supabase.auth.getSession().\\u003cwbr\\u003ethen(({ data }) \\u003d\\u0026gt; {\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      if (data.session \\u0026amp;\\u0026amp; CONFIG.adminEmails.includes(\\u003cwbr\\u003edata.session.user.email)){\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        showAdmin(data.session.user.\\u003cwbr\\u003eemail);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;/script\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;/body\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;/html\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003c/div\\u003e\\r\\n\"],2094601652]],0,null,null,null,1,0],\"\\u003c!DOCTYPE html\\u003e\\u003chtml lang\\u003d\\\"pt-BR\\\"\\u003e\\u003chead\\u003e\\u003cmeta charset\\u003d\\\"UTF-8\\\"\\u003e\\u003cmeta name\\u003d\\\"viewport\\\" content\\u003d\\\"width\\u003ddevice-width, initial-scale\\u003d1.0\\\"\\u003e\\u003ctitle\\u003ePainel — Clube de Van\",[\"^all\",\"^fhas\",\"^i\",\"^iim\",\"^io_im\",\"^io_imc3\",\"^o\",\"^smartlabel_personal\",\"^sq_ig_i_personal\"],null,null,\"\\u003cCAE4rHSYpmwE4fXS2RG5gfNNWembVZ\\u003dk7uLR\\u003dPdDtRLB\\u003d4g83Yw@mail.gmail.com\\u003e\",null,null,null,1782293372726,[0,0,\"\",-1,null,null,null,\"gmail.com\",\"gmail.com\",null,1,null,null,null,null,null,\"ricardocontreras19988@gmail.com\",1,null,0],null,null,[1,\"ricardocontreras102030@gmail.com\"],null,null,null,null,null,null,null,[null,null,null,[1],[0.56950337],null,null,[40510407,40510372],null,1],1782293372726,null,null,null,null,[null,null,null,null,2],null,null,null,null,null,null,null,0,[null,null,1],null,null,null,null,null,null,null,null,null,null,\"19ef8f69f36506c0\",null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,[],null,null,null,null,null,null,[0,null,1,1,1],null,null,null,null,[0],null,null,null,null,[null,null,null,null,null,null,null,null,[1782293377668]],[0],null,null,null,null,0]],null,null,null,null,null,[null,null,null,null,null,null,null,null,[1782293377668]],null,null,0.56950337,null,null,0,null,null,\"19ef8f69f36506c0\",null,null,null,null,[[1],\"en\",\"en\"]],0,0,[[\"^o\"],[\"^iim\"],[\"^s\",null,null,2],[\"^sq_ig_i_personal\"],[\"^g\"],[\"^smartlabel_personal\"],[\"^i\",null,null,2],[\"^io_im\",null,null,2],[\"^k\",null,null,2],[\"^io_imc3\"],[\"^fhas\"],[\"^all\",null,null,2]],2],[0,[\"README\",\"# Clube de Vantagens — Template White-Label ## Deploy no Vercel 1. Crie um repositório novo no GitHub e suba só o `index.html` (na raiz). 2. Entre no Vercel → \\\"Add New Project\\\" → importe o\",1782292187349,\"thread-f:1868868812446497376\",[[\"msg-f:1868868812446497376\",[1,\"ricardocontreras19988@gmail.com\",\"Ricardo Contreras\"],[[1,\"ricardocontreras102030@gmail.com\"]],null,null,null,1782292187349,\"README\",[null,[[0,null,[null,\"\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e# Clube de Vantagens — Template White-Label\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e## Deploy no Vercel\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e1. Crie um repositório novo no GitHub e suba só o `index.html` (na raiz).\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e2. Entre no Vercel → \\u0026quot;Add New Project\\u0026quot; → importe o repositório.\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e3. Não precisa configurar nada — o Vercel detecta como site estático e publica direto.\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e## Personalizar pra cada cliente\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003eAbra o `index.html`, vá até o bloco `CONFIG` no final do arquivo (perto da tag `\\u0026lt;script\\u0026gt;`) e troque:\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e- `brand`: nome da marca do cliente (aparece no topo, no cartão e no rodapé)\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e- `city`: cidade/região do cliente\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e- `whatsapp`: número de contato no formato 5575999999999\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e- `monthlySavings`: valor do contador de economia\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003ePra trocar as cores, edite as variáveis no topo do `\\u0026lt;style\\u0026gt;` (`--navy`, `--gold`, `--coral`, `--river`).\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003ePra trocar os parceiros de exemplo pelos reais do cliente, edite o array `partners` no `\\u0026lt;script\\u0026gt;`.\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e## Painel de administração (admin.html)\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003eAgora existe uma página separada — `admin.html` — onde você (ou o cliente) loga como administrador e cadastra/remove parceiros de verdade. Isso aparece automaticamente no site, sem editar código.\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003ePassos:\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e1. No `admin.html`, preencha `supabaseUrl` e `supabaseAnonKey` (os mesmos do `index.html`).\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e2. Em `adminEmails`, coloque o e-mail que vai administrar (pode ser o seu, ou o do cliente).\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e3. No Supabase, vá em **Authentication → Users** e crie manualmente esse usuário admin (ou crie pelo próprio cadastro do site e depois promova ele).\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e4. Rode esse SQL adicional no **SQL Editor**:\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e```sql\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003ecreate table public.partners (\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  id uuid default gen_random_uuid() primary key,\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  cat text not null,\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  name text not null,\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  description text not null,\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  tag text not null,\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  created_at timestamptz default now()\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003ealter table public.partners enable row level security;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003ecreate policy \\u0026quot;qualquer pessoa pode ver parceiros\\u0026quot; on public.partners\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  for select using (true);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003ecreate policy \\u0026quot;admin pode inserir parceiros\\u0026quot; on public.partners\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  for insert with check (auth.jwt() -\\u0026gt;\\u0026gt; \\u0026#39;email\\u0026#39; in (\\u0026#39;\\u003ca href\\u003d\\\"mailto:seu-email@exemplo.com\\\" target\\u003d\\\"_blank\\\"\\u003eseu-email@exemplo.com\\u003c/a\\u003e\\u0026#39;));\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003ecreate policy \\u0026quot;admin pode remover parceiros\\u0026quot; on public.partners\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  for delete using (auth.jwt() -\\u0026gt;\\u0026gt; \\u0026#39;email\\u0026#39; in (\\u0026#39;\\u003ca href\\u003d\\\"mailto:seu-email@exemplo.com\\\" target\\u003d\\\"_blank\\\"\\u003eseu-email@exemplo.com\\u003c/a\\u003e\\u0026#39;));\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e```\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003eTroque `\\u0026#39;\\u003ca href\\u003d\\\"mailto:seu-email@exemplo.com\\\" target\\u003d\\\"_blank\\\"\\u003eseu-email@exemplo.com\\u003c/a\\u003e\\u0026#39;` pelo e-mail real do admin (tem que ser o mesmo que está em `adminEmails` no `admin.html`).\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e5. Suba o `admin.html` no mesmo repositório do `index.html` (na raiz, junto). Depois do deploy, o painel fica em `\\u003ca href\\u003d\\\"http://seusite.vercel.app/admin.html\\\" target\\u003d\\\"_blank\\\" data-saferedirecturl\\u003d\\\"https://www.google.com/url?q\\u003dhttp://seusite.vercel.app/admin.html\\u0026amp;source\\u003dgmail\\u0026amp;ust\\u003d1782379798329000\\u0026amp;usg\\u003dAOvVaw3Pc7go4i5EvtQkMNatS651\\\"\\u003eseusite.vercel.app/admin.\\u003cwbr\\u003ehtml`\\u003c/a\\u003e.\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003eEnquanto nenhum parceiro for cadastrado, o site mostra automaticamente os exemplos (farmácia, restaurante, etc.) — assim nunca fica vazio.\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e## Pra ativar o login com conta (Supabase — gratuito)\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003eA página já tem todo o código de login/cadastro pronto. Falta só conectar a um banco de dados real, que é de graça pra começar:\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e1. Crie uma conta em \\u003ca href\\u003d\\\"https://supabase.com\\\" target\\u003d\\\"_blank\\\" data-saferedirecturl\\u003d\\\"https://www.google.com/url?q\\u003dhttps://supabase.com\\u0026amp;source\\u003dgmail\\u0026amp;ust\\u003d1782379798329000\\u0026amp;usg\\u003dAOvVaw1bCHTmTwqjV2rmd2UOOyrp\\\"\\u003ehttps://supabase.com\\u003c/a\\u003e e um novo projeto.\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e2. Em **Project Settings → API**, copie a **Project URL** e a **anon public key**.\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e3. No `index.html`, ache o bloco `CONFIG` e cole esses dois valores em `supabaseUrl` e `supabaseAnonKey`.\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e4. No Supabase, vá em **SQL Editor** e rode:\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e```sql\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003ecreate table public.members (\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  id uuid references auth.users on delete cascade primary key,\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  name text not null,\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  card_number text not null,\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  created_at timestamp with time zone default now()\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003ealter table public.members enable row level security;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003ecreate policy \\u0026quot;select own profile\\u0026quot; on public.members\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  for select using (auth.uid() \\u003d id);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003ecreate policy \\u0026quot;insert own profile\\u0026quot; on public.members\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  for insert with check (auth.uid() \\u003d id);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e```\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e5. Em **Authentication → Providers**, deixe \\u0026quot;Email\\u0026quot; ativado (já vem por padrão).\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e6. Em **Authentication → Settings**, se quiser pular a confirmação por e-mail (mais rápido pra testar), desative \\u0026quot;Confirm email\\u0026quot;.\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003eDepois disso, o botão \\u0026quot;Entrar\\u0026quot; abre o cadastro/login de verdade: a pessoa cria conta, recebe um número de cartão gerado automaticamente, e ao voltar no site já entra logada.\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e## O que tem na página\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e- Cartão de membro animado (visual de cartão físico com efeito de brilho)\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e- Busca de categorias/parceiros\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e- 9 categorias de desconto\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e- Grade de parceiros em destaque\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e- Seção \\u0026quot;como funciona\\u0026quot;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e- Chamada para empresas que querem entrar no clube (WhatsApp)\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003c/div\\u003e\\r\\n\"],-1458535938]],0,null,null,null,1,0],\"# Clube de Vantagens — Template White-Label ## Deploy no Vercel1. Crie um repositório novo no GitHub e suba só o `index.html` (na raiz).2. Entre no Vercel → \\\"Ad\",[\"^all\",\"^fhas\",\"^i\",\"^iim\",\"^io_im\",\"^io_imc3\",\"^io_lr\",\"^io_lr2m\",\"^io_lr30s\",\"^o\",\"^smartlabel_personal\",\"^sq_ig_i_personal\"],null,null,\"\\u003cCAE4rHSbxuZQgGPUz2nDim9_e4GNQ3KLr-feKRtnyQv2aKYfGkA@mail.gmail.com\\u003e\",null,null,null,1782292187162,[0,0,\"\",-1,null,null,null,\"gmail.com\",\"gmail.com\",null,1,null,null,null,null,null,\"ricardocontreras19988@gmail.com\",1,null,0],null,null,[1,\"ricardocontreras102030@gmail.com\"],null,null,null,null,null,null,null,[null,null,null,[1],[0.54826444],null,null,[40510407,40510372],null,1],1782292187162,null,null,null,null,[null,null,null,null,2],null,null,null,null,null,null,null,0,[null,null,1],null,null,null,null,null,null,null,null,null,null,\"19ef8e4881adfa60\",null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,[],null,null,null,null,null,null,[0,null,1,1,1],null,null,null,null,[0],null,null,null,null,[null,null,null,null,null,null,null,null,[1782292980515]],[0],null,null,null,null,0]],null,null,null,null,null,[null,null,null,null,null,null,null,null,[1782292980515]],null,null,0.54826444,null,null,0,null,null,\"19ef8e4881adfa60\",null,null,null,null,[[1],\"en\",\"en\"]],0,0,[[\"^io_lr\"],[\"^iim\"],[\"^sq_ig_i_personal\"],[\"^io_lr30s\"],[\"^io_lr2m\"],[\"^g\"],[\"^i\",null,null,2],[\"^k\",null,null,2],[\"^fhas\"],[\"^all\",null,null,2],[\"^o\"],[\"^s\",null,null,2],[\"^smartlabel_personal\"],[\"^io_im\",null,null,2],[\"^io_imc3\"]],2],[0,[\"Admin\",\"\\u003c!DOCTYPE html\\u003e \\u003chtml lang\\u003d\\\"pt-BR\\\"\\u003e \\u003chead\\u003e \\u003cmeta charset\\u003d\\\"UTF-8\\\"\\u003e \\u003cmeta name\\u003d\\\"viewport\\\" content\\u003d\\\"width\\u003ddevice-width, initial-scale\\u003d1.0\",1782292988200,\"thread-f:1868869652111715213\",[[\"msg-f:1868869652111715213\",[1,\"ricardocontreras19988@gmail.com\",\"Ricardo Contreras\"],[[1,\"ricardocontreras102030@gmail.com\"]],null,null,null,1782292988200,\"Admin\",[null,[[0,null,[null,\"\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;!DOCTYPE html\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;html lang\\u003d\\u0026quot;pt-BR\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;head\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;meta charset\\u003d\\u0026quot;UTF-8\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;meta name\\u003d\\u0026quot;viewport\\u0026quot; content\\u003d\\u0026quot;width\\u003ddevice-width, initial-scale\\u003d1.0\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;title\\u0026gt;Painel — Clube de Vantagens\\u0026lt;/title\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;script src\\u003d\\u0026quot;\\u003ca href\\u003d\\\"https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2\\\" target\\u003d\\\"_blank\\\" data-saferedirecturl\\u003d\\\"https://www.google.com/url?q\\u003dhttps://cdn.jsdelivr.net/npm/@supabase/supabase-js@2\\u0026amp;source\\u003dgmail\\u0026amp;ust\\u003d1782379798333000\\u0026amp;usg\\u003dAOvVaw1hSu2qaWqfjsICr6AL3On2\\\"\\u003ehttps://cdn.jsdelivr.net/\\u003cwbr\\u003enpm/@supabase/supabase-js@2\\u003c/a\\u003e\\u0026quot;\\u0026gt;\\u0026lt;\\u003cwbr\\u003e/script\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;link href\\u003d\\u0026quot;\\u003ca href\\u003d\\\"https://fonts.googleapis.com/css2?family\\u003dSora:wght@700;800\\u0026amp;family\\u003dInter:wght@400;500;600;700\\u0026amp;display\\u003dswap\\\" target\\u003d\\\"_blank\\\" data-saferedirecturl\\u003d\\\"https://www.google.com/url?q\\u003dhttps://fonts.googleapis.com/css2?family%3DSora:wght@700;800%26family%3DInter:wght@400;500;600;700%26display%3Dswap\\u0026amp;source\\u003dgmail\\u0026amp;ust\\u003d1782379798333000\\u0026amp;usg\\u003dAOvVaw3s0URmBnKe4FOSULBFut2P\\\"\\u003ehttps://fonts.\\u003cwbr\\u003egoogleapis.com/css2?family\\u003d\\u003cwbr\\u003eSora:wght@700;800\\u0026amp;family\\u003d\\u003cwbr\\u003eInter:wght@400;500;600;700\\u0026amp;\\u003cwbr\\u003edisplay\\u003dswap\\u003c/a\\u003e\\u0026quot; rel\\u003d\\u0026quot;stylesheet\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;style\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e:root{\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  --navy:#0B1F3A; --coral:#FF6B4A; --river:#178A8A; --cream:#FAF7F1;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  --ink:#13161B; --ink-soft:#5B6472; --line:#E7E1D6;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  --display:\\u0026#39;Sora\\u0026#39;, sans-serif; --body:\\u0026#39;Inter\\u0026#39;, sans-serif;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e*{margin:0;padding:0;box-\\u003cwbr\\u003esizing:border-box;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003ebody{font-family:var(--body);\\u003cwbr\\u003ebackground:var(--cream);color:\\u003cwbr\\u003evar(--ink);min-height:100vh;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.wrap{max-width:640px;margin:0 auto;padding:30px 20px 60px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003eh1{font-family:var(--display);\\u003cwbr\\u003efont-weight:800;color:var(--\\u003cwbr\\u003enavy);font-size:1.4rem;margin-\\u003cwbr\\u003ebottom:4px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.sub{color:var(--ink-soft);\\u003cwbr\\u003efont-size:0.85rem;margin-\\u003cwbr\\u003ebottom:28px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.card{background:#fff;border:\\u003cwbr\\u003e1px solid var(--line);border-radius:\\u003cwbr\\u003e16px;padding:20px;margin-\\u003cwbr\\u003ebottom:16px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003elabel{font-size:0.8rem;font-\\u003cwbr\\u003eweight:600;color:var(--ink-\\u003cwbr\\u003esoft);display:flex;flex-\\u003cwbr\\u003edirection:column;gap:6px;\\u003cwbr\\u003emargin-bottom:12px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003einput{border:1px solid var(--line);border-radius:\\u003cwbr\\u003e10px;padding:10px 12px;font-size:0.95rem;font-\\u003cwbr\\u003efamily:var(--body);outline:\\u003cwbr\\u003enone;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003einput:focus{border-color:var(-\\u003cwbr\\u003e-river);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn{font-family:var(--\\u003cwbr\\u003edisplay);font-weight:700;font-\\u003cwbr\\u003esize:0.85rem;padding:11px 18px;border-radius:999px;\\u003cwbr\\u003eborder:none;cursor:pointer;\\u003cwbr\\u003edisplay:inline-flex;align-\\u003cwbr\\u003eitems:center;gap:6px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-dark{background:var(--\\u003cwbr\\u003enavy);color:#fff;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-coral{background:var(--\\u003cwbr\\u003ecoral);color:#fff;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-outline{background:\\u003cwbr\\u003etransparent;border:1.5px solid var(--line);color:var(--ink);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-danger{background:#fff;\\u003cwbr\\u003ecolor:var(--coral);border:1.\\u003cwbr\\u003e5px solid var(--coral);font-size:0.\\u003cwbr\\u003e78rem;padding:7px 14px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.error{color:var(--coral);\\u003cwbr\\u003efont-size:0.82rem;min-height:\\u003cwbr\\u003e1em;margin-top:-4px;margin-\\u003cwbr\\u003ebottom:8px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-row{display:flex;\\u003cwbr\\u003ejustify-content:space-between;\\u003cwbr\\u003ealign-items:flex-start;gap:\\u003cwbr\\u003e12px;border-bottom:1px solid var(--line);padding:14px 0;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-row:last-child{\\u003cwbr\\u003eborder-bottom:none;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-row .info strong{display:block;font-\\u003cwbr\\u003efamily:var(--display);color:\\u003cwbr\\u003evar(--navy);font-size:0.95rem;\\u003cwbr\\u003e}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-row .info span{font-size:0.78rem;color:\\u003cwbr\\u003evar(--river);font-weight:600;\\u003cwbr\\u003etext-transform:uppercase;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-row .info p{font-size:0.82rem;color:var(\\u003cwbr\\u003e--ink-soft);margin-top:4px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.tag{display:inline-block;\\u003cwbr\\u003ebackground:var(--coral);color:\\u003cwbr\\u003e#fff;font-size:0.72rem;font-\\u003cwbr\\u003eweight:700;padding:2px 8px;border-radius:999px;\\u003cwbr\\u003emargin-top:4px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e#loginView, #adminView{display:none;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e#loginView.active, #adminView.active{display:\\u003cwbr\\u003eblock;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.topbar{display:flex;justify-\\u003cwbr\\u003econtent:space-between;align-\\u003cwbr\\u003eitems:center;margin-bottom:\\u003cwbr\\u003e24px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.hint{font-size:0.78rem;color:\\u003cwbr\\u003evar(--ink-soft);background:#\\u003cwbr\\u003efff;border:1px solid var(--line);border-radius:\\u003cwbr\\u003e12px;padding:14px;margin-\\u003cwbr\\u003ebottom:20px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;/style\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;/head\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;body\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;div class\\u003d\\u0026quot;wrap\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  \\u0026lt;div id\\u003d\\u0026quot;loginView\\u0026quot; class\\u003d\\u0026quot;active\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;h1\\u0026gt;Painel do Clube\\u0026lt;/h1\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;p class\\u003d\\u0026quot;sub\\u0026quot;\\u0026gt;Entre com sua conta de administrador pra gerenciar os parceiros.\\u0026lt;/p\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;div class\\u003d\\u0026quot;card\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;form id\\u003d\\u0026quot;loginForm\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;label\\u0026gt;E-mail\\u0026lt;input type\\u003d\\u0026quot;email\\u0026quot; id\\u003d\\u0026quot;loginEmail\\u0026quot; required\\u0026gt;\\u0026lt;/label\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;label\\u0026gt;Senha\\u0026lt;input type\\u003d\\u0026quot;password\\u0026quot; id\\u003d\\u0026quot;loginPassword\\u0026quot; required\\u0026gt;\\u0026lt;/label\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;p class\\u003d\\u0026quot;error\\u0026quot; id\\u003d\\u0026quot;loginError\\u0026quot;\\u0026gt;\\u0026lt;/p\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;button class\\u003d\\u0026quot;btn btn-dark\\u0026quot; type\\u003d\\u0026quot;submit\\u0026quot;\\u0026gt;Entrar\\u0026lt;/button\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;/form\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;p class\\u003d\\u0026quot;hint\\u0026quot;\\u0026gt;Esse login é só pra quem administra o clube (você ou o cliente dono da marca) — é diferente do cadastro de clientes finais no site.\\u0026lt;/p\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  \\u0026lt;div id\\u003d\\u0026quot;adminView\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;div class\\u003d\\u0026quot;topbar\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;h1\\u0026gt;Parceiros\\u0026lt;/h1\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;p class\\u003d\\u0026quot;sub\\u0026quot; id\\u003d\\u0026quot;welcomeMsg\\u0026quot;\\u0026gt;\\u0026lt;/p\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;button class\\u003d\\u0026quot;btn btn-outline\\u0026quot; id\\u003d\\u0026quot;logoutBtn\\u0026quot;\\u0026gt;Sair\\u0026lt;/button\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;div class\\u003d\\u0026quot;card\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;h3 style\\u003d\\u0026quot;font-family:var(--\\u003cwbr\\u003edisplay);color:var(--navy);\\u003cwbr\\u003emargin-bottom:14px;\\u0026quot;\\u0026gt;Adicionar parceiro\\u0026lt;/h3\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;form id\\u003d\\u0026quot;partnerForm\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;label\\u0026gt;Categoria\\u0026lt;input type\\u003d\\u0026quot;text\\u0026quot; id\\u003d\\u0026quot;pCat\\u0026quot; placeholder\\u003d\\u0026quot;Ex: Saúde\\u0026quot; required\\u0026gt;\\u0026lt;/label\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;label\\u0026gt;Nome do negócio\\u0026lt;input type\\u003d\\u0026quot;text\\u0026quot; id\\u003d\\u0026quot;pName\\u0026quot; placeholder\\u003d\\u0026quot;Ex: Farmácia São Francisco\\u0026quot; required\\u0026gt;\\u0026lt;/label\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;label\\u0026gt;Descrição da oferta\\u0026lt;input type\\u003d\\u0026quot;text\\u0026quot; id\\u003d\\u0026quot;pDesc\\u0026quot; placeholder\\u003d\\u0026quot;Ex: Desconto em medicamentos\\u0026quot; required\\u0026gt;\\u0026lt;/label\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;label\\u0026gt;Desconto (etiqueta)\\u0026lt;input type\\u003d\\u0026quot;text\\u0026quot; id\\u003d\\u0026quot;pTag\\u0026quot; placeholder\\u003d\\u0026quot;Ex: -18%\\u0026quot; required\\u0026gt;\\u0026lt;/label\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;p class\\u003d\\u0026quot;error\\u0026quot; id\\u003d\\u0026quot;partnerError\\u0026quot;\\u0026gt;\\u0026lt;/p\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;button class\\u003d\\u0026quot;btn btn-coral\\u0026quot; type\\u003d\\u0026quot;submit\\u0026quot;\\u0026gt;Adicionar parceiro\\u0026lt;/button\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;/form\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;div class\\u003d\\u0026quot;card\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;h3 style\\u003d\\u0026quot;font-family:var(--\\u003cwbr\\u003edisplay);color:var(--navy);\\u003cwbr\\u003emargin-bottom:8px;\\u0026quot;\\u0026gt;Parceiros cadastrados\\u0026lt;/h3\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;div id\\u003d\\u0026quot;partnersList\\u0026quot;\\u0026gt;\\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u0026lt;script\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  // \\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003cwbr\\u003e\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  // Use os MESMOS valores de supabaseUrl/supabaseAnonKey do index.html\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  // E coloque seu e-mail (ou o do cliente) na lista de admins abaixo\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  // E TAMBÉM na política SQL do Supabase (veja o README).\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  // \\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003cwbr\\u003e\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003d\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  const CONFIG \\u003d {\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    supabaseUrl: \\u0026quot;SUA_SUPABASE_URL_AQUI\\u0026quot;,\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    supabaseAnonKey: \\u0026quot;SUA_SUPABASE_ANON_KEY_AQUI\\u0026quot;,\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    adminEmails: [\\u0026quot;\\u003ca href\\u003d\\\"mailto:seu-email@exemplo.com\\\" target\\u003d\\\"_blank\\\"\\u003eseu-email@exemplo.com\\u003c/a\\u003e\\u0026quot;]\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  };\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  const ready \\u003d CONFIG.supabaseUrl.startsWith(\\u003cwbr\\u003e\\u0026#39;http\\u0026#39;) \\u0026amp;\\u0026amp; CONFIG.supabaseAnonKey.length \\u0026gt; 20;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  if (!ready){\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    document.body.innerHTML \\u003d \\u0026#39;\\u0026lt;div class\\u003d\\u0026quot;wrap\\u0026quot;\\u0026gt;\\u0026lt;h1\\u0026gt;Painel não configurado\\u0026lt;/h1\\u0026gt;\\u0026lt;p class\\u003d\\u0026quot;sub\\u0026quot;\\u0026gt;Preencha CONFIG.supabaseUrl e CONFIG.supabaseAnonKey neste arquivo (admin.html), igual já fez no index.html.\\u0026lt;/p\\u0026gt;\\u0026lt;/div\\u0026gt;\\u0026#39;;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  } else {\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const supabase \\u003d window.supabase.createClient(\\u003cwbr\\u003eCONFIG.supabaseUrl, CONFIG.supabaseAnonKey);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const loginView \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003eloginView\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const adminView \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003eadminView\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const loginForm \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003eloginForm\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const loginError \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003eloginError\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const partnerForm \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003epartnerForm\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const partnerError \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003epartnerError\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const partnersList \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003epartnersList\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const logoutBtn \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003elogoutBtn\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const welcomeMsg \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003ewelcomeMsg\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    function showLogin(){ loginView.classList.add(\\u0026#39;\\u003cwbr\\u003eactive\\u0026#39;); adminView.classList.remove(\\u0026#39;\\u003cwbr\\u003eactive\\u0026#39;); }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    function showAdmin(email){\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      loginView.classList.remove(\\u0026#39;\\u003cwbr\\u003eactive\\u0026#39;); adminView.classList.add(\\u0026#39;\\u003cwbr\\u003eactive\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      welcomeMsg.textContent \\u003d `Logado como ${email}`;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      loadPartners();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    loginForm.addEventListener(\\u0026#39;\\u003cwbr\\u003esubmit\\u0026#39;, async (e) \\u003d\\u0026gt; {\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      e.preventDefault();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      loginError.textContent \\u003d \\u0026#39;\\u0026#39;;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const email \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003eloginEmail\\u0026#39;).value;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const password \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003eloginPassword\\u0026#39;).value;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const { data, error } \\u003d await supabase.auth.\\u003cwbr\\u003esignInWithPassword({ email, password });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      if (error){ loginError.textContent \\u003d \\u0026#39;E-mail ou senha incorretos.\\u0026#39;; return; }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      if (!CONFIG.adminEmails.includes(\\u003cwbr\\u003edata.user.email)){\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        loginError.textContent \\u003d \\u0026#39;Esta conta não tem acesso ao painel de administração.\\u0026#39;;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        await supabase.auth.signOut();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        return;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      showAdmin(data.user.email);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    logoutBtn.addEventListener(\\u0026#39;\\u003cwbr\\u003eclick\\u0026#39;, async () \\u003d\\u0026gt; {\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      await supabase.auth.signOut();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      showLogin();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    partnerForm.addEventListener(\\u0026#39;\\u003cwbr\\u003esubmit\\u0026#39;, async (e) \\u003d\\u0026gt; {\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      e.preventDefault();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      partnerError.textContent \\u003d \\u0026#39;\\u0026#39;;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const cat \\u003d document.getElementById(\\u0026#39;pCat\\u0026#39;\\u003cwbr\\u003e).value;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const name \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003epName\\u0026#39;).value;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const description \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003epDesc\\u0026#39;).value;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const tag \\u003d document.getElementById(\\u0026#39;pTag\\u0026#39;\\u003cwbr\\u003e).value;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const { error } \\u003d await supabase.from(\\u0026#39;partners\\u0026#39;).\\u003cwbr\\u003einsert({ cat, name, description, tag });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      if (error){ partnerError.textContent \\u003d \\u0026#39;Erro ao salvar: \\u0026#39; + error.message; return; }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      partnerForm.reset();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      loadPartners();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\