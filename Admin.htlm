wbr\\u003e3px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.wrap{max-width:1140px;margin:\\u003cwbr\\u003e0 auto;padding:0 20px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e/* TOPBAR */\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.topbar{position:sticky;top:0;\\u003cwbr\\u003ez-index:50;background:rgba(\\u003cwbr\\u003e250,247,241,0.95);backdrop-\\u003cwbr\\u003efilter:blur(14px);border-\\u003cwbr\\u003ebottom:1px solid var(--line);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.topbar .wrap{display:flex;align-\\u003cwbr\\u003eitems:center;justify-content:\\u003cwbr\\u003espace-between;height:64px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.logo{font-family:var(--\\u003cwbr\\u003edisplay);font-weight:800;font-\\u003cwbr\\u003esize:1rem;color:var(--navy);\\u003cwbr\\u003edisplay:flex;align-items:\\u003cwbr\\u003ecenter;gap:8px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.logo .dot{width:9px;height:9px;\\u003cwbr\\u003eborder-radius:50%;background:\\u003cwbr\\u003evar(--coral);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.topbar-actions{display:flex;\\u003cwbr\\u003egap:8px;align-items:center;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e/* BOTÕES */\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn{\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  font-family:var(--display);\\u003cwbr\\u003efont-weight:700;font-size:0.\\u003cwbr\\u003e85rem;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  padding:11px 20px;border-radius:999px;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  transition:transform .18s ease, box-shadow .18s ease, background .18s ease;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  display:inline-flex;align-\\u003cwbr\\u003eitems:center;gap:7px;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  cursor:pointer;border:none;\\u003cwbr\\u003ewhite-space:nowrap;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn svg{flex:none;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-ghost{background:\\u003cwbr\\u003etransparent;color:var(--navy);\\u003cwbr\\u003eborder:1.5px solid var(--line);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-ghost:hover{border-color:\\u003cwbr\\u003evar(--navy);background:rgba(\\u003cwbr\\u003e11,31,58,0.04);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-dark{background:var(--\\u003cwbr\\u003enavy);color:#fff;box-shadow:0 6px 20px -8px rgba(11,31,58,0.5);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-dark:hover{transform:\\u003cwbr\\u003etranslateY(-2px);box-shadow:0 12px 24px -8px rgba(11,31,58,0.6);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-coral{background:var(--\\u003cwbr\\u003ecoral);color:#fff;box-shadow:0 6px 20px -8px rgba(255,107,74,0.5);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-coral:hover{transform:\\u003cwbr\\u003etranslateY(-2px);box-shadow:0 12px 24px -8px rgba(255,107,74,0.6);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-gold{background:var(--\\u003cwbr\\u003egold);color:#fff;box-shadow:0 6px 20px -8px rgba(201,162,39,0.5);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-gold:hover{transform:\\u003cwbr\\u003etranslateY(-2px);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-outline-coral{background:\\u003cwbr\\u003etransparent;color:var(--coral)\\u003cwbr\\u003e;border:1.5px solid var(--coral);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.btn-outline-coral:hover{\\u003cwbr\\u003ebackground:rgba(255,107,74,0.\\u003cwbr\\u003e06);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e/* HERO */\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.hero{position:relative;\\u003cwbr\\u003epadding:52px 0 44px;background:radial-\\u003cwbr\\u003egradient(120% 90% at 50% -10%,rgba(23,138,138,0.10),\\u003cwbr\\u003etransparent 60%),var(--cream);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.eyebrow{font-family:var(--\\u003cwbr\\u003emono);font-size:0.72rem;\\u003cwbr\\u003eletter-spacing:0.12em;color:\\u003cwbr\\u003evar(--river);text-transform:\\u003cwbr\\u003euppercase;font-weight:600;\\u003cwbr\\u003edisplay:inline-flex;align-\\u003cwbr\\u003eitems:center;gap:8px;margin-\\u003cwbr\\u003ebottom:18px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.eyebrow::before{content:\\u0026quot;\\u0026quot;;\\u003cwbr\\u003ewidth:18px;height:1px;\\u003cwbr\\u003ebackground:var(--river);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.hero h1{font-family:var(--display);\\u003cwbr\\u003efont-weight:800;font-size:\\u003cwbr\\u003eclamp(2.1rem,7vw,3.2rem);line-\\u003cwbr\\u003eheight:1.05;color:var(--navy);\\u003cwbr\\u003eletter-spacing:-0.01em;max-\\u003cwbr\\u003ewidth:11ch;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.hero h1 em{font-style:normal;color:\\u003cwbr\\u003evar(--coral);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.hero p.lead{margin-top:16px;max-\\u003cwbr\\u003ewidth:38ch;color:var(--ink-\\u003cwbr\\u003esoft);font-size:1.05rem;line-\\u003cwbr\\u003eheight:1.55;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.hero-ctas{display:flex;gap:\\u003cwbr\\u003e12px;margin-top:28px;flex-\\u003cwbr\\u003ewrap:wrap;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e/* CARTÃO */\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.card-stage{margin-top:40px;\\u003cwbr\\u003edisplay:flex;justify-content:\\u003cwbr\\u003ecenter;perspective:1000px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.vcard{width:min(320px,86vw);\\u003cwbr\\u003easpect-ratio:1.586/1;border-\\u003cwbr\\u003eradius:18px;position:relative;\\u003cwbr\\u003ebackground:linear-gradient(\\u003cwbr\\u003e135deg,var(--navy) 0%,var(--navy-2) 55%,var(--navy) 100%);box-shadow:0 30px 60px -20px rgba(11,31,58,0.55),0 0 0 1px rgba(255,255,255,0.04) inset;color:#fff;overflow:\\u003cwbr\\u003ehidden;transform:rotate3d(1,-\\u003cwbr\\u003e1,0,8deg);transition:transform .4s ease;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.card-stage:hover .vcard{transform:rotate3d(1,-\\u003cwbr\\u003e1,0,2deg) scale(1.02);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.vcard::before{content:\\u0026quot;\\u0026quot;;\\u003cwbr\\u003eposition:absolute;left:-10%;\\u003cwbr\\u003ebottom:-30%;width:130%;height:\\u003cwbr\\u003e80%;background:repeating-\\u003cwbr\\u003elinear-gradient(100deg,\\u003cwbr\\u003etransparent 0 18px,rgba(23,138,138,0.18) 18px 20px);transform:rotate(-6deg);\\u003cwbr\\u003eopacity:0.7;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.vcard::after{content:\\u0026quot;\\u0026quot;;\\u003cwbr\\u003eposition:absolute;top:0;left:-\\u003cwbr\\u003e60%;width:40%;height:100%;\\u003cwbr\\u003ebackground:linear-gradient(\\u003cwbr\\u003e100deg,transparent,rgba(255,\\u003cwbr\\u003e255,255,0.18),transparent);\\u003cwbr\\u003eanimation:shine 4.5s ease-in-out infinite;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e@keyframes shine{0%{left:-60%;}45%{left:\\u003cwbr\\u003e130%;}100%{left:130%;}}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.vcard-inner{position:\\u003cwbr\\u003erelative;z-index:2;height:100%\\u003cwbr\\u003e;display:flex;flex-direction:\\u003cwbr\\u003ecolumn;justify-content:space-\\u003cwbr\\u003ebetween;padding:20px 22px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.vcard-top{display:flex;\\u003cwbr\\u003ejustify-content:space-between;\\u003cwbr\\u003ealign-items:flex-start;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.vcard-brand{font-family:var(-\\u003cwbr\\u003e-display);font-weight:800;\\u003cwbr\\u003efont-size:1rem;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.vcard-tier{font-family:var(--\\u003cwbr\\u003emono);font-size:0.62rem;\\u003cwbr\\u003eletter-spacing:0.1em;color:\\u003cwbr\\u003evar(--gold-soft);border:1px solid rgba(228,199,102,0.5);padding:\\u003cwbr\\u003e3px 8px;border-radius:999px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.vcard-chip{width:34px;height:\\u003cwbr\\u003e24px;border-radius:5px;\\u003cwbr\\u003ebackground:linear-gradient(\\u003cwbr\\u003e135deg,var(--gold-soft),var(--\\u003cwbr\\u003egold));margin-top:10px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.vcard-number{font-family:var(\\u003cwbr\\u003e--mono);font-size:1rem;letter-\\u003cwbr\\u003espacing:0.18em;color:#fff;\\u003cwbr\\u003eopacity:0.9;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.vcard-bottom{display:flex;\\u003cwbr\\u003ejustify-content:space-between;\\u003cwbr\\u003ealign-items:flex-end;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.vcard-name{font-family:var(--\\u003cwbr\\u003emono);font-size:0.72rem;\\u003cwbr\\u003eletter-spacing:0.06em;color:\\u003cwbr\\u003ergba(255,255,255,0.75);text-\\u003cwbr\\u003etransform:uppercase;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.vcard-since{font-family:var(-\\u003cwbr\\u003e-mono);font-size:0.65rem;\\u003cwbr\\u003ecolor:rgba(255,255,255,0.55);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e/* BUSCA */\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.search-row{margin-top:34px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.search-box{display:flex;\\u003cwbr\\u003ealign-items:center;gap:10px;\\u003cwbr\\u003ebackground:#fff;border:1px solid var(--line);border-radius:\\u003cwbr\\u003e999px;padding:13px 18px;max-width:560px;margin:0 auto;box-shadow:0 10px 30px -20px rgba(11,31,58,0.3);transition:\\u003cwbr\\u003ebox-shadow .2s;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.search-box:focus-within{box-\\u003cwbr\\u003eshadow:0 10px 30px -15px rgba(11,31,58,0.4);border-\\u003cwbr\\u003ecolor:var(--river);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.search-box input{flex:1;border:none;\\u003cwbr\\u003eoutline:none;font-size:1rem;\\u003cwbr\\u003efont-family:var(--body);\\u003cwbr\\u003ebackground:transparent;color:\\u003cwbr\\u003evar(--ink);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.search-box input::placeholder{color:#\\u003cwbr\\u003e9aa3b0;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e/* CONTADOR */\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.counter-strip{margin-top:\\u003cwbr\\u003e24px;display:flex;justify-\\u003cwbr\\u003econtent:center;gap:6px;align-\\u003cwbr\\u003eitems:baseline;font-family:\\u003cwbr\\u003evar(--mono);color:var(--navy);\\u003cwbr\\u003e}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.counter-strip .num{font-size:1.5rem;font-\\u003cwbr\\u003eweight:700;color:var(--coral);\\u003cwbr\\u003e}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.counter-strip .label{font-size:0.85rem;\\u003cwbr\\u003ecolor:var(--ink-soft);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e/* SEÇÃO */\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003esection{padding:64px 0;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.sec-head{margin-bottom:28px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.sec-eyebrow{font-family:var(-\\u003cwbr\\u003e-mono);font-size:0.7rem;\\u003cwbr\\u003eletter-spacing:0.1em;color:\\u003cwbr\\u003evar(--coral);text-transform:\\u003cwbr\\u003euppercase;font-weight:600;\\u003cwbr\\u003emargin-bottom:8px;display:\\u003cwbr\\u003eblock;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.sec-head h2{font-family:var(--display);\\u003cwbr\\u003efont-weight:800;color:var(--\\u003cwbr\\u003enavy);font-size:clamp(1.5rem,\\u003cwbr\\u003e4vw,2rem);letter-spacing:-0.\\u003cwbr\\u003e01em;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.sec-head p{color:var(--ink-soft);\\u003cwbr\\u003emargin-top:8px;max-width:46ch;\\u003cwbr\\u003e}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e/* CATEGORIAS — foto circular */\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.cat-scroll{display:flex;gap:\\u003cwbr\\u003e18px;overflow-x:auto;padding-\\u003cwbr\\u003ebottom:12px;scroll-snap-type:x proximity;-ms-overflow-style:\\u003cwbr\\u003enone;scrollbar-width:none;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.cat-scroll::-webkit-\\u003cwbr\\u003escrollbar{display:none;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.cat-pill{flex:none;scroll-\\u003cwbr\\u003esnap-align:start;display:flex;\\u003cwbr\\u003eflex-direction:column;align-\\u003cwbr\\u003eitems:center;gap:10px;width:\\u003cwbr\\u003e88px;cursor:pointer;\\u003cwbr\\u003etransition:opacity .2s;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.cat-pill:hover .cat-photo{transform:scale(1.\\u003cwbr\\u003e06);box-shadow:0 8px 24px -8px rgba(11,31,58,0.35);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.cat-photo{width:80px;height:\\u003cwbr\\u003e80px;border-radius:50%;\\u003cwbr\\u003eoverflow:hidden;border:3px solid #fff;box-shadow:0 4px 16px -8px rgba(11,31,58,0.22);\\u003cwbr\\u003etransition:transform .2s,box-shadow .2s;position:relative;\\u003cwbr\\u003ebackground:var(--line);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.cat-photo img{width:100%;height:100%;\\u003cwbr\\u003eobject-fit:cover;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.cat-photo .cat-overlay{position:\\u003cwbr\\u003eabsolute;inset:0;border-\\u003cwbr\\u003eradius:50%;background:linear-\\u003cwbr\\u003egradient(160deg,transparent,\\u003cwbr\\u003ergba(11,31,58,0.15));}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.cat-label{font-family:var(--\\u003cwbr\\u003edisplay);font-size:0.78rem;\\u003cwbr\\u003efont-weight:700;color:var(--\\u003cwbr\\u003enavy);text-align:center;line-\\u003cwbr\\u003eheight:1.2;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e/* BANNER rotativo */\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.banner-wrap{margin-top:28px;\\u003cwbr\\u003eborder-radius:20px;overflow:\\u003cwbr\\u003ehidden;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.banner-track{display:flex;\\u003cwbr\\u003etransition:transform .5s cubic-bezier(.4,0,.2,1);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.bcard{flex:none;width:100%;\\u003cwbr\\u003eheight:168px;display:flex;\\u003cwbr\\u003ealign-items:center;padding:0 28px;position:relative;\\u003cwbr\\u003eoverflow:hidden;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.bcard .bc-deco{position:absolute;\\u003cwbr\\u003eright:-30px;bottom:-30px;\\u003cwbr\\u003ewidth:160px;height:160px;\\u003cwbr\\u003eborder-radius:50%;background:\\u003cwbr\\u003ergba(255,255,255,0.1);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.bcard .bc-deco2{position:absolute;\\u003cwbr\\u003eright:60px;top:-40px;width:\\u003cwbr\\u003e100px;height:100px;border-\\u003cwbr\\u003eradius:50%;background:rgba(\\u003cwbr\\u003e255,255,255,0.07);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.bcard .bc-text{position:relative;z-\\u003cwbr\\u003eindex:2;max-width:70%;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.bcard .bc-tag{font-family:var(--\\u003cwbr\\u003emono);font-size:0.62rem;\\u003cwbr\\u003eletter-spacing:0.1em;text-\\u003cwbr\\u003etransform:uppercase;opacity:0.\\u003cwbr\\u003e8;margin-bottom:6px;display:\\u003cwbr\\u003eblock;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.bcard .bc-text h3{font-family:var(--display);\\u003cwbr\\u003efont-weight:800;font-size:1.\\u003cwbr\\u003e1rem;line-height:1.2;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.bcard .bc-text p{font-size:0.8rem;margin-top:\\u003cwbr\\u003e5px;opacity:0.85;max-width:\\u003cwbr\\u003e30ch;line-height:1.4;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.bcard .bc-btn{display:inline-flex;\\u003cwbr\\u003ealign-items:center;gap:6px;\\u003cwbr\\u003emargin-top:12px;font-family:\\u003cwbr\\u003evar(--display);font-size:0.\\u003cwbr\\u003e78rem;font-weight:700;padding:\\u003cwbr\\u003e8px 16px;border-radius:999px;\\u003cwbr\\u003etransition:transform .15s;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.bcard .bc-btn:hover{transform:\\u003cwbr\\u003etranslateY(-1px);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.banner-dots{display:flex;gap:\\u003cwbr\\u003e6px;justify-content:center;\\u003cwbr\\u003emargin-top:10px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.banner-dots button{width:7px;height:7px;\\u003cwbr\\u003eborder-radius:50%;background:\\u003cwbr\\u003evar(--line);transition:\\u003cwbr\\u003ebackground .3s,width .3s,border-radius .3s;padding:0;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.banner-dots button.active{background:var(-\\u003cwbr\\u003e-coral);width:22px;border-\\u003cwbr\\u003eradius:4px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e/* PARCEIROS */\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partners-grid{display:grid;\\u003cwbr\\u003egrid-template-columns:repeat(\\u003cwbr\\u003e2,1fr);gap:14px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-card{background:#fff;\\u003cwbr\\u003eborder:1px solid var(--line);border-radius:var(\\u003cwbr\\u003e--radius);padding:20px;\\u003cwbr\\u003eposition:relative;overflow:\\u003cwbr\\u003ehidden;transition:box-shadow .2s,transform .2s;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-card:hover{transform:\\u003cwbr\\u003etranslateY(-2px);box-shadow:0 14px 30px -16px rgba(11,31,58,0.25);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-tag{position:\\u003cwbr\\u003eabsolute;top:14px;right:14px;\\u003cwbr\\u003ebackground:var(--coral);color:\\u003cwbr\\u003e#fff;font-family:var(--mono);\\u003cwbr\\u003efont-size:0.7rem;font-weight:\\u003cwbr\\u003e600;padding:4px 9px;border-radius:999px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-cat{font-size:0.\\u003cwbr\\u003e72rem;color:var(--river);font-\\u003cwbr\\u003eweight:600;text-transform:\\u003cwbr\\u003euppercase;letter-spacing:0.\\u003cwbr\\u003e06em;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-card h4{font-family:var(--display);\\u003cwbr\\u003efont-size:1.05rem;color:var(--\\u003cwbr\\u003enavy);margin-top:6px;font-\\u003cwbr\\u003eweight:700;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-card p{font-size:0.85rem;color:var(\\u003cwbr\\u003e--ink-soft);margin-top:6px;\\u003cwbr\\u003eline-height:1.4;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.partner-cta{margin-top:14px;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e/* PASSOS */\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.steps{display:flex;flex-\\u003cwbr\\u003edirection:column;gap:0;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.step{display:flex;gap:20px;\\u003cwbr\\u003epadding:22px 0;border-bottom:1px solid var(--line);}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e.step:last-child{border-\\u003cwbr\\u003ebottom:none;}\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\