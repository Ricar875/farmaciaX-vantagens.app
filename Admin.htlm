\\\\"auto\\\\\\\"\\\\u003ebody{font-family:var(--body);\\\\u003cwbr\\\\u003ebackground:var(--cream);color:\\\\u003cwbr\\\\u003evar(--ink);min-height:100vh;}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e.wrap{max-width:640px;margin:0 auto;padding:30px 20px 60px;}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003eh1{font-family:var(--display);\\\\u003cwbr\\\\u003efont-weight:800;color:var(--\\\\u003cwbr\\\\u003enavy);font-size:1.4rem;margin-\\\\u003cwbr\\\\u003ebottom:4px;}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e.sub{color:var(--ink-soft);\\\\u003cwbr\\\\u003efont-size:0.85rem;margin-\\\\u003cwbr\\\\u003ebottom:28px;}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e.card{background:#fff;border:\\\\u003cwbr\\\\u003e1px solid var(--line);border-radius:\\\\u003cwbr\\\\u003e16px;padding:20px;margin-\\\\u003cwbr\\\\u003ebottom:16px;}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003elabel{font-size:0.8rem;font-\\\\u003cwbr\\\\u003eweight:600;color:var(--ink-\\\\u003cwbr\\\\u003esoft);display:flex;flex-\\\\u003cwbr\\\\u003edirection:column;gap:6px;\\\\u003cwbr\\\\u003emargin-bottom:12px;}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003einput{border:1px solid var(--line);border-radius:\\\\u003cwbr\\\\u003e10px;padding:10px 12px;font-size:0.95rem;font-\\\\u003cwbr\\\\u003efamily:var(--body);outline:\\\\u003cwbr\\\\u003enone;}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003einput:focus{border-color:var(-\\\\u003cwbr\\\\u003e-river);}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e.btn{font-family:var(--\\\\u003cwbr\\\\u003edisplay);font-weight:700;font-\\\\u003cwbr\\\\u003esize:0.85rem;padding:11px 18px;border-radius:999px;\\\\u003cwbr\\\\u003eborder:none;cursor:pointer;\\\\u003cwbr\\\\u003edisplay:inline-flex;align-\\\\u003cwbr\\\\u003eitems:center;gap:6px;}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e.btn-dark{background:var(--\\\\u003cwbr\\\\u003enavy);color:#fff;}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e.btn-coral{background:var(--\\\\u003cwbr\\\\u003ecoral);color:#fff;}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e.btn-outline{background:\\\\u003cwbr\\\\u003etransparent;border:1.5px solid var(--line);color:var(--ink);}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e.btn-danger{background:#fff;\\\\u003cwbr\\\\u003ecolor:var(--coral);border:1.\\\\u003cwbr\\\\u003e5px solid var(--coral);font-size:0.\\\\u003cwbr\\\\u003e78rem;padding:7px 14px;}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e.error{color:var(--coral);\\\\u003cwbr\\\\u003efont-size:0.82rem;min-height:\\\\u003cwbr\\\\u003e1em;margin-top:-4px;margin-\\\\u003cwbr\\\\u003ebottom:8px;}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e.partner-row{display:flex;\\\\u003cwbr\\\\u003ejustify-content:space-between;\\\\u003cwbr\\\\u003ealign-items:flex-start;gap:\\\\u003cwbr\\\\u003e12px;border-bottom:1px solid var(--line);padding:14px 0;}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e.partner-row:last-child{\\\\u003cwbr\\\\u003eborder-bottom:none;}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e.partner-row .info strong{display:block;font-\\\\u003cwbr\\\\u003efamily:var(--display);color:\\\\u003cwbr\\\\u003evar(--navy);font-size:0.95rem;\\\\u003cwbr\\\\u003e}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e.partner-row .info span{font-size:0.78rem;color:\\\\u003cwbr\\\\u003evar(--river);font-weight:600;\\\\u003cwbr\\\\u003etext-transform:uppercase;}\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e.partner-row .info p{font-size:0.82rem;color:var(\\\\u003cwbr\\\\u003e--ink-soft);