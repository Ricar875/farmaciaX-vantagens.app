 destaque, sempre!\\u0026quot;, sub:\\u0026quot;Atraia, retenha e surpreenda seus clientes todo dia.\\u0026quot;, ctaLabel:\\u0026quot;Ver planos\\u0026quot;, ctaHref:\\u0026quot;#planos\\u0026quot;, ctaBg:\\u0026quot;#C9A227\\u0026quot;, ctaColor:\\u0026quot;#fff\\u0026quot; }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  ];\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  const bannerWrap \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003ebannerWrap\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  const bannerDots \\u003d document.getElementById(\\u0026#39;\\u003cwbr\\u003ebannerDots\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  let cur \\u003d 0;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  let autoTimer \\u003d null;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  bannerWrap.innerHTML \\u003d `\\u0026lt;div class\\u003d\\u0026quot;banner-track\\u0026quot; id\\u003d\\u0026quot;bannerTrack\\u0026quot;\\u0026gt;${banners.\\u003cwbr\\u003emap(b \\u003d\\u0026gt; `\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;div class\\u003d\\u0026quot;bcard\\u0026quot; style\\u003d\\u0026quot;background:${\\u003ca href\\u003d\\\"http://b.bg\\\" target\\u003d\\\"_blank\\\" data-saferedirecturl\\u003d\\\"https://www.google.com/url?q\\u003dhttp://b.bg\\u0026amp;source\\u003dgmail\\u0026amp;ust\\u003d1782379798348000\\u0026amp;usg\\u003dAOvVaw01ZcTnP5piJTzH0w_SwMUi\\\"\\u003eb.bg\\u003c/a\\u003e};\\u003cwbr\\u003ecolor:#fff;\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;div class\\u003d\\u0026quot;bc-deco\\u0026quot;\\u0026gt;\\u0026lt;/div\\u0026gt;\\u0026lt;div class\\u003d\\u0026quot;bc-deco2\\u0026quot;\\u0026gt;\\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;div class\\u003d\\u0026quot;bc-text\\u0026quot;\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;span class\\u003d\\u0026quot;bc-tag\\u0026quot;\\u0026gt;${b.tag}\\u0026lt;/span\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;h3\\u0026gt;${b.title}\\u0026lt;/h3\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;p\\u0026gt;${b.sub}\\u0026lt;/p\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e        \\u0026lt;a class\\u003d\\u0026quot;bc-btn\\u0026quot; href\\u003d\\u0026quot;${b.ctaHref}\\u0026quot; style\\u003d\\u0026quot;background:${b.ctaBg};\\u003cwbr\\u003ecolor:${b.ctaColor};\\u0026quot; target\\u003d\\u0026quot;${b.ctaHref.\\u003cwbr\\u003estartsWith(\\u0026#39;http\\u0026#39;) ? \\u0026#39;_blank\\u0026#39; : \\u0026#39;_self\\u0026#39;}\\u0026quot; rel\\u003d\\u0026quot;noopener\\u0026quot;\\u0026gt;${b.ctaLabel}\\u0026lt;/\\u003cwbr\\u003ea\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    \\u0026lt;/div\\u0026gt;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  `).join(\\u0026#39;\\u0026#39;)}\\u0026lt;/div\\u0026gt;`;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  bannerDots.innerHTML \\u003d banners.map((_, i) \\u003d\\u0026gt; `\\u0026lt;button class\\u003d\\u0026quot;${i \\u003d\\u003d\\u003d 0 ? \\u0026#39;active\\u0026#39; : \\u0026#39;\\u0026#39;}\\u0026quot; data-i\\u003d\\u0026quot;${i}\\u0026quot; aria-label\\u003d\\u0026quot;Banner ${i + 1}\\u0026quot;\\u0026gt;\\u0026lt;/button\\u0026gt;`).join(\\u0026#39;\\u0026#39;);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  function goBanner(n){\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    cur \\u003d (n + banners.length) % banners.length;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    document.getElementById(\\u0026#39;\\u003cwbr\\u003ebannerTrack\\u0026#39;).style.transform \\u003d `translateX(-${cur * 100}%)`;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    document.querySelectorAll(\\u0026#39;.\\u003cwbr\\u003ebanner-dots button\\u0026#39;).forEach((dot, i) \\u003d\\u0026gt; dot.classList.toggle(\\u0026#39;active\\u0026#39;, i \\u003d\\u003d\\u003d cur));\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  function startAuto(){\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    stopAuto();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    autoTimer \\u003d setInterval(() \\u003d\\u0026gt; goBanner(cur + 1), 4500);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  function stopAuto(){\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    if (autoTimer) clearInterval(autoTimer);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  document.querySelectorAll(\\u0026#39;.\\u003cwbr\\u003ebanner-dots button\\u0026#39;).forEach(dot \\u003d\\u0026gt; {\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    dot.addEventListener(\\u0026#39;click\\u0026#39;, () \\u003d\\u0026gt; { goBanner(Number(dot.dataset.i)\\u003cwbr\\u003e); startAuto(); });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  bannerWrap.addEventListener(\\u0026#39;\\u003cwbr\\u003emouseenter\\u0026#39;, stopAuto);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  bannerWrap.addEventListener(\\u0026#39;\\u003cwbr\\u003emouseleave\\u0026#39;, startAuto);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  startAuto();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  // ---------- parceiros ----------\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  // Carrega do banco (cadastrados no painel admin.html). Se não houver\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  // nenhum cadastrado ainda, mostra os exemplos abaixo pra a página\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  // nunca ficar vazia.\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  const exemploPartners \\u003d [\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    { cat:\\u0026quot;Saúde\\u0026quot;, name:\\u0026quot;Farmácia São Francisco\\u0026quot;, description:\\u0026quot;Desconto em medicamentos e produtos de higiene\\u0026quot;, tag:\\u0026quot;-18%\\u0026quot; },\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    { cat:\\u0026quot;Sabor Local\\u0026quot;, name:\\u0026quot;Restaurante Sabor da Terra\\u0026quot;, description:\\u0026quot;Almoço executivo de seg a sex\\u0026quot;, tag:\\u0026quot;-15%\\u0026quot; },\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    { cat:\\u0026quot;Autocuidado\\u0026quot;, name:\\u0026quot;Espaço Bella Estética\\u0026quot;, description:\\u0026quot;Limpeza de pele e massagem relaxante\\u0026quot;, tag:\\u0026quot;-20%\\u0026quot; },\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    { cat:\\u0026quot;Cuidados Pet\\u0026quot;, name:\\u0026quot;Vet \\u0026amp; Cia Clínica Veterinária\\u0026quot;, description:\\u0026quot;Consulta e vacinas com desconto\\u0026quot;, tag:\\u0026quot;-10%\\u0026quot; },\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    { cat:\\u0026quot;Serviços Daqui\\u0026quot;, name:\\u0026quot;Oficina Central Auto Center\\u0026quot;, description:\\u0026quot;Revisão completa e troca de óleo\\u0026quot;, tag:\\u0026quot;-12%\\u0026quot; }\\u003c/div\\u003