iv dir\\u003d\\\"auto\\\"\\u003e  function runCounter(){\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    if (counted) return;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    counted \\u003d true;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const duration \\u003d 1200;\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    const startTime \\u003d performance.now();\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    function tick(now){\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const progress \\u003d Math.min((now - startTime) / duration, 1);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      const eased \\u003d 1 - Math.pow(1 - progress, 3);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      counterEl.textContent \\u003d formatBRL(Math.floor(eased * CONFIG.monthlySavings));\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e      if (progress \\u0026lt; 1) requestAnimationFrame(tick);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    requestAnimationFrame(tick);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  }\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  new IntersectionObserver((entries) \\u003d\\u0026gt; {\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e    entries.forEach(e \\u003d\\u0026gt; { if (e.isIntersecting) runCounter(); });\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  }, { threshold: 0.5 }).observe(counterEl);\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e\\u003cbr\\u003e\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  // ---------- busca (filtra categorias) ----------\\u003c/div\\u003e\\u003cdiv dir\\u003d\\\"auto\\\"\\u003e  document.getElementById(\\u0026#39;\\u003cwbr\\u003esearchInput\\u0026#39;).\\u003cwbr\\u003eaddEventListener(\\u0026#39;input\\u0026#39;, function(){\\u003c/div\\u003e\\u003cdiv dir