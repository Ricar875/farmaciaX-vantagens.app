26lt;/div\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e      `).join(\\\\u0026#39;\\\\u0026#39;);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e      partnersList.querySelectorAll(\\\\u003cwbr\\\\u003e\\\\u0026#39;button[data-id]\\\\u0026#39;).forEach(btn \\\\u003d\\\\u0026gt; {\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e        btn.addEventListener(\\\\u0026#39;click\\\\u0026#39;, async () \\\\u003d\\\\u0026gt; {\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e          if (!confirm(\\\\u0026#39;Remover este parceiro?\\\\u0026#39;)) return;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e          await supabase.from(\\\\u0026#39;partners\\\\u0026#39;).\\\\u003cwbr\\\\u003edelete().eq(\\\\u0026#39;id\\\\u0026#39;, \\\\u003ca href\\\\u003d\\\\\\\"http://btn.dataset.id\\\\\\\" target\\\\u003d\\\\\\\"_blank\\\\\\\" data-saferedirecturl\\\\u003d\\\\\\\"https://www.google.com/url?q\\\\u003dhttp://btn.dataset.id\\\\u0026amp;source\\\\u003dgmail\\\\u0026amp;ust\\\\u003d1782379798321000\\\\u0026amp;usg\\\\u003dAOvVaw02A81nJDNq4071LaS2jlyn\\\\\\\"\\\\u003ebtn.dataset.id\\\\u003c/a\\\\u003e);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e          loadPartners();\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e        });\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e      });\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    }\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    // mantém logado se já tinha sessão\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    supabase.auth.getSession().\\\\u003cwbr\\\\u003ethen(({ data }) \\\\u003d\\\\u0026gt; {\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e      if (data.session \\\\u0026amp;\\\\u0026amp; CONFIG.adminEmails.includes(\\\\u003cwbr\\\\u003edata.session.user.email)){\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e        showAdmin(data.session.user.\\\\u003cwbr\\\\u003eemail);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e      }\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    });\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  }\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u0026lt;/script\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u0026lt;/body\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u0026lt;/html\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003c/div\\\\u003e\\\\r\\\\n\\\"],2094601652]],0,null,null,null,1,0],\\\"\\\\u003c!DOCTYPE html\\\\u003e\\\\u003chtml lang\\\\u003d\\\\\\\"pt-BR\\\\\\\"\\\\u003e\\\\u003chead\\\\u003e\\\\u003cmeta charset\\\\u003d\\\\\\\"UTF-8\\\\\\\"\\\\u003e\\\\u003cmeta name\\\\u003d\\\\\\\"viewport\\\\\\\" content\\\\u003d\\\\\\\"width\\\\u003ddevice-width, initial-scale\\\\u003d1.0\\\\\\\"\\\\u003e\\\\u003ctitle\\\\u003ePainel \\u2014 Clube de Van\\\",\\\"\\\\u003cCAE4rHSYpmwE4fXS2RG5gfNNWembVZ\\\\u003dk7uLR\\\\u003dPdDtRLB\\\\u003d4g83Yw@mail.gmail.com\\\\u003e\\\",null,null,[0,0,\\\"\\\",-1,null,null,null,\\\"gmail.com\\\",\\\"gmail.com\\\",null,1,null,null,null,null,null,\\\"ricardocontreras19988@gmail.com\\\",1,null,0],[1,\\\"ricardocontreras102030@gmail.com\\\"],null,null,null,null,1782293372726,null,null,[null,null,null,null,2],{\\\"35\\\":\\\"19ef8f69f36506c0\\\",\\\"55\\\":0}]\",\"f\":false,\"g\":8,\"i\":false,\"j\":\"1868870055599867584\"},{\"a\":3,\"b\":\"msg-f:1868868812446497376\",\"c\":3,\"d\":\"[[[1,\\\"ricardocontreras102030@gmail.com\\\"]],null,null,null,\\\"README\\\",[null,[[0,null,[null,\\\"\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e# Clube de Vantagens \\u2014 Template White-Label\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e## Deploy no Vercel\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e1. Crie um repositório novo no GitHub e suba só o `index.html` (na raiz).\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e2. Entre no Vercel → \\\\u0026quot;Add New Project\\\\u0026quot; → importe o repositório.\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e3. Não precisa configurar nada \\u2014 o Vercel detecta como site estático e publica direto.\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e## Personalizar pra cada cliente\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003eAbra o `index.html`, vá até o bloco `CONFIG` no final do arquivo (perto da tag `\\\\u0026lt;script\\\\u0026gt;`) e troque:\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e- `brand`: nome da marca do cliente (aparece no topo, no cartão e no rodapé)\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e- `city`: cidade/região do cliente\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e- `whatsapp`: número de contato no formato 5575999999999\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e- `monthlySavings`: valor do contador de economia\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003ePra trocar as cores, edite as variáveis no topo do `\\\\u0026lt;style\\\\u0026gt;` (`--navy`, `--gold`, `--coral`, `--river`).\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003ePra trocar os parceiros de exemplo pelos reais do cliente, edite o array `partners` no `\\\\u0026lt;script\\\\u0026gt;`.\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e## Painel de administração (admin.html)\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003eAgora existe uma página separada \\u2014 `admin.html` \\u2014 onde você (ou o cliente) loga como administrador e cadastra/remove parceiros de verdade. Isso aparece automaticamente no site, sem editar código.\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003ePassos:\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e1. No `admin.html`, preencha `supabaseUrl` e `supabaseAnonKey` (os mesmos do `index.html`).\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e2. Em `adminEmails`, coloque o e-mail que vai administrar (pode ser o seu, ou o do cliente).\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e3. No Supabase, vá em **Authentication → Users** e crie manualmente esse usuário admin (ou crie pelo próprio cadastro do site e depois promova ele).\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e4. Rode esse SQL adicional no **SQL Editor**:\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e```sql\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003ecreate table public.partners (\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  id uuid default gen_random_uuid() primary key,\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  cat text not null,\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  name text not null,\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  description text not null,\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  tag text not null,\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  created_at timestamptz default now()\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003ealter table public.partners enable row level security;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003ecreate policy \\\\u0026quot;qualquer pessoa pode ver parceiros\\\\u0026quot; on public.partners\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  for select using (true);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003ecreate policy \\\\u0026quot;admin pode inserir parceiros\\\\u0026quot; on public.partners\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  for insert with check (auth.jwt() -\\\\u0026gt;\\\\u0026gt; \\\\u0026#39;email\\\\u0026#39; in (\\\\u0026#39;\\\\u003ca href\\\\u003d\\\\\\\"mailto:seu-email@exemplo.com\\\\\\\" target\\\\u003d\\\\\\\"_blank\\\\\\\"\\\\u003eseu-email@exemplo.com\\\\u003c/a\\\\u003e\\\\u0026#39;));\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003ecreate policy \\\\u0026quot;admin pode remover parceiros\\\\u0026quot; on public.partners\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  for delete using (auth.jwt() -\\\\u0026gt;\\\\u0026gt; \\\\u0026#39;email\\\\u0026#39; in (\\\\u0026#39;\\\\u003ca href\\\\u003d\\\\\\\"mailto:seu-email@exemplo.com\\\\\\\" target\\\\u003d\\\\\\\"_blank\\\\\\\"\\\\u003eseu-email@exemplo.com\\\\u003c/a\\\\u003e\\\\u0026#39;));\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e```\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003eTroque `\\\\u0026#39;\\\\u003ca href\\\\u003d\\\\\\\"mailto:seu-email@exemplo.com\\\\\\\" target\\\\u003d\\\\\\\"_blank\\\\\\\"\\\\u003eseu-email@exemplo.com\\\\u003c/a\\\\u003e\\\\u0026#39;` pelo e-mail real do admin (tem que ser o mesmo que está em `adminEmails` no `admin.html`).\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e5. Suba o `admin.html` no mesmo repositório do `index.html` (na raiz, junto). Depois do deploy, o painel fica em `\\\\u003ca href\\\\u003d\\\\\\\"http://seusite.vercel.app/admin.html\\\\\\\" target\\\\u003d\\\\\\\"_blank\\\\\\\" data-saferedirecturl\\\\u003d\\\\\\\"https://www.google.com/url?q\\\\u003dhttp://seusite.vercel.app/admin.html\\\\u0026amp;source\\\\u003dgmail\\\\u0026amp;ust\\\\u003d1782379798329000\\\\u0026amp;usg\\\\u003dAOvVaw3Pc7go4i5EvtQkMNatS651\\\\\\\"\\\\u003eseusite.vercel.app/admin.\\\\u003cwbr\\\\u003ehtml`\\\\u003c/a\\\\u003e.\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003eEnquanto nenhum parceiro for cadastrado, o site mostra automaticamente os exemplos (farmácia, restaurante, etc.) \\u2014 assim nunca fica vazio.\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e## Pra ativar o login com conta (Supabase \\u2014 gratuito)\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003eA página já tem todo o código de login/cadastro pronto. Falta só conectar a um banco de dados real, que é de graça pra começar:\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e1. Crie uma conta em \\\\u003ca href\\\\u003d\\\\\\\"https://supabase.com\\\\\\\" target\\\\u003d\\\\\\\"_blank\\\\\\\" data-saferedirecturl\\\\u003d\\\\\\\"https://www.google.com/url?q\\\\u003dhttps://supabase.com\\\\u0026amp;source\\\\u003dgmail\\\\u0026amp;ust\\\\u003d1782379798329000\\\\u0026amp;usg\\\\u003dAOvVaw1bCHTmTwqjV2rmd2UOOyrp\\\\\\\"\\\\u003ehttps://supabase.com\\\\u003c/a\\\\u003e e um novo projeto.\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e2. Em **Project Settings → API**, copie a **Project URL** e a **anon public key**.\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e3. No `index.html`, ache o bloco `CONFIG` e cole esses dois valores em `supabaseUrl` e `supabaseAnonKey`.\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e4. No Supabase, vá em **SQL Editor** e rode:\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e```sql\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003ecreate table public.members (\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  id uuid references auth.users on delete cascade primary key,\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  name text not null,\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  card_number text not null,\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  created_at timestamp with time zone default now()\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003ealter table public.members enable row level security;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003ecreate policy \\\\u0026quot;select own profile\\\\u0026quot; on public.members\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  for select using (auth.uid() \\\\u003d id);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003ecreate policy \\\\u0026quot;insert own profile\\\\u0026quot; on public.members\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  for insert with check (auth.uid() \\\\u003d id);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e```\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e5. Em **Authentication → Providers**, deixe \\\\u0026quot;Email\\\\u0026quot; ativado (já vem por padrão).\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e6. Em **Authentication → Settings**, se quiser pular a confirmação por e-mail (mais rápido pra testar), desative \\\\u0026quot;Confirm email\\\\u0026quot;.\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003eDepois disso, o botão \\\\u0026quot;Entrar\\\\u0026quot; abre o cadastro/login de verdade: a pessoa cria conta, recebe um número de cartão gerado automaticamente, e ao voltar no site já entra logada.\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e## O que tem na página\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e- Cartão de membro animado (visual de cartão físico com efeito de brilho)\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e- Busca de categorias/parceiros\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e- 9 categorias de desconto\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e- Grade de parceiros em destaque\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e- Seção \\\\u0026quot;como funciona\\\\u0026quot;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e- Chamada para empresas que querem entrar no clube (WhatsApp)\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003c/div\\\\u003e\\\\r\\\\n\\\"],-1458535938]],0,null,null,null,1,0],\\\"# Clube de Vantagens \\u2014 Template White-Label ## Deploy no Vercel1. Crie um repositório novo no GitHub e suba só o `index.html` (na raiz).2. Entre no Vercel → \\\\\\\"Ad\\\",\\\"\\\\u003cCAE4rHSbxuZQgGPUz2nDim9_e4GNQ3KLr-feKRtnyQv2aKYfGkA@mail.gmail.com\\\\u003e\\\",null,null,[0,0,\\\"\\\",-1,null,null,null,\\\"gmail.com\\\",\\\"gmail.com\\\",null,1,null,null,null,null,null,\\\"ricardocontreras19988@gmail.com\\\"