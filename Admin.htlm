\\\u003d\\\\u0026quot;font-family:var(--\\\\u003cwbr\\\\u003edisplay);color:var(--navy);\\\\u003cwbr\\\\u003emargin-bottom:14px;\\\\u0026quot;\\\\u0026gt;Adicionar parceiro\\\\u0026lt;/h3\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e      \\\\u0026lt;form id\\\\u003d\\\\u0026quot;partnerForm\\\\u0026quot;\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e        \\\\u0026lt;label\\\\u0026gt;Categoria\\\\u0026lt;input type\\\\u003d\\\\u0026quot;text\\\\u0026quot; id\\\\u003d\\\\u0026quot;pCat\\\\u0026quot; placeholder\\\\u003d\\\\u0026quot;Ex: Saúde\\\\u0026quot; required\\\\u0026gt;\\\\u0026lt;/label\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e        \\\\u0026lt;label\\\\u0026gt;Nome do negócio\\\\u0026lt;input type\\\\u003d\\\\u0026quot;text\\\\u0026quot; id\\\\u003d\\\\u0026quot;pName\\\\u0026quot; placeholder\\\\u003d\\\\u0026quot;Ex: Farmácia São Francisco\\\\u0026quot; required\\\\u0026gt;\\\\u0026lt;/label\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e        \\\\u0026lt;label\\\\u0026gt;Descrição da oferta\\\\u0026lt;input type\\\\u003d\\\\u0026quot;text\\\\u0026quot; id\\\\u003d\\\\u0026quot;pDesc\\\\u0026quot; placeholder\\\\u003d\\\\u0026quot;Ex: Desconto em medicamentos\\\\u0026quot; required\\\\u0026gt;\\\\u0026lt;/label\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e        \\\\u0026lt;label\\\\u0026gt;Desconto (etiqueta)\\\\u0026lt;input type\\\\u003d\\\\u0026quot;text\\\\u0026quot; id\\\\u003d\\\\u0026quot;pTag\\\\u0026quot; placeholder\\\\u003d\\\\u0026quot;Ex: -18%\\\\u0026quot; required\\\\u0026gt;\\\\u0026lt;/label\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e        \\\\u0026lt;p class\\\\u003d\\\\u0026quot;error\\\\u0026quot; id\\\\u003d\\\\u0026quot;partnerError\\\\u0026quot;\\\\u0026gt;\\\\u0026lt;/p\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e        \\\\u0026lt;button class\\\\u003d\\\\u0026quot;btn btn-coral\\\\u0026quot; type\\\\u003d\\\\u0026quot;submit\\\\u0026quot;\\\\u0026gt;Adicionar parceiro\\\\u0026lt;/button\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e      \\\\u0026lt;/form\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    \\\\u0026lt;/div\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    \\\\u0026lt;div class\\\\u003d\\\\u0026quot;card\\\\u0026quot;\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e      \\\\u0026lt;h3 style\\\\u003d\\\\u0026quot;font-family:var(--\\\\u003cwbr\\\\u003edisplay);color:var(--navy);\\\\u003cwbr\\\\u003emargin-bottom:8px;\\\\u0026quot;\\\\u0026gt;Parceiros cadastrados\\\\u0026lt;/h3\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e      \\\\u0026lt;div id\\\\u003d\\\\u0026quot;partnersList\\\\u0026quot;\\\\u0026gt;\\\\u0026lt;/div\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    \\\\u0026lt;/div\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  \\\\u0026lt;/div\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u0026lt;/div\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u0026lt;script\\\\u0026gt;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  // \\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003cwbr\\\\u003e\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  // Use os MESMOS valores de supabaseUrl/supabaseAnonKey do index.html\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  // E coloque seu e-mail (ou o do cliente) na lista de admins abaixo\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  // E TAMBÉM na política SQL do Supabase (veja o README).\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  // \\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003cwbr\\\\u003e\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003d\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  const CONFIG \\\\u003d {\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    supabaseUrl: \\\\u0026quot;SUA_SUPABASE_URL_AQUI\\\\u0026quot;,\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    supabaseAnonKey: \\\\u0026quot;SUA_SUPABASE_ANON_KEY_AQUI\\\\u0026quot;,\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    adminEmails: [\\\\u0026quot;\\\\u003ca href\\\\u003d\\\\\\\"mailto:seu-email@exemplo.com\\\\\\\" target\\\\u003d\\\\\\\"_blank\\\\\\\"\\\\u003eseu-email@exemplo.com\\\\u003c/a\\\\u003e\\\\u0026quot;]\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  };\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  const ready \\\\u003d CONFIG.supabaseUrl.startsWith(\\\\u003cwbr\\\\u003e\\\\u0026#39;http\\\\u0026#39;) \\\\u0026amp;\\\\u0026amp; CONFIG.supabaseAnonKey.length \\\\u0026gt; 20;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  if (!ready){\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    document.body.innerHTML \\\\u003d \\\\u0026#39;\\\\u0026lt;div class\\\\u003d\\\\u0026quot;wrap\\\\u0026quot;\\\\u0026gt;\\\\u0026lt;h1\\\\u0026gt;Painel não configurado\\\\u0026lt;/h1\\\\u0026gt;\\\\u0026lt;p class\\\\u003d\\\\u0026quot;sub\\\\u0026quot;\\\\u0026gt;Preencha CONFIG.supabaseUrl e CONFIG.supabaseAnonKey neste arquivo (admin.html), igual já fez no index.html.\\\\u0026lt;/p\\\\u0026gt;\\\\u0026lt;/div\\\\u0026gt;\\\\u0026#39;;\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e  } else {\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    const supabase \\\\u003d window.supabase.createClient(\\\\u003cwbr\\\\u003eCONFIG.supabaseUrl, CONFIG.supabaseAnonKey);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    const loginView \\\\u003d document.getElementById(\\\\u0026#39;\\\\u003cwbr\\\\u003eloginView\\\\u0026#39;);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    const adminView \\\\u003d document.getElementById(\\\\u0026#39;\\\\u003cwbr\\\\u003eadminView\\\\u0026#39;);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    const loginForm \\\\u003d document.getElementById(\\\\u0026#39;\\\\u003cwbr\\\\u003eloginForm\\\\u0026#39;);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    const loginError \\\\u003d document.getElementById(\\\\u0026#39;\\\\u003cwbr\\\\u003eloginError\\\\u0026#39;);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    const partnerForm \\\\u003d document.getElementById(\\\\u0026#39;\\\\u003cwbr\\\\u003epartnerForm\\\\u0026#39;);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    const partnerError \\\\u003d document.getElementById(\\\\u0026#39;\\\\u003cwbr\\\\u003epartnerError\\\\u0026#39;);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    const partnersList \\\\u003d document.getElementById(\\\\u0026#39;\\\\u003cwbr\\\\u003epartnersList\\\\u0026#39;);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    const logoutBtn \\\\u003d document.getElementById(\\\\u0026#39;\\\\u003cwbr\\\\u003elogoutBtn\\\\u0026#39;);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    const welcomeMsg \\\\u003d document.getElementById(\\\\u0026#39;\\\\u003cwbr\\\\u003ewelcomeMsg\\\\u0026#39;);\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e\\\\u003cbr\\\\u003e\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    function showLogin(){ loginView.classList.add(\\\\u0026#39;\\\\u003cwbr\\\\u003eactive\\\\u0026#39;); adminView.classList.remove(\\\\u0026#39;\\\\u003cwbr\\\\u003eactive\\\\u0026#39;); }\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e    function showAdmin(email){\\\\u003c/div\\\\u003e\\\\u003cdiv dir\\\\u003d\\\\\\\"auto\\\\\\\"\\\\u003e      loginView.classList.remove(\\\\u0026#39;\\\\u003cwbr\\\\u003eactive\\\\